# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Entra ID (app registration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint / Microsoft Graph
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
SHAREPOINT_LIST_ID=

# IANA timezone the SharePoint site displays dates in (Graph stores dates in
# UTC; user-typed calendar dates are interpreted in this zone). E.g.
# Europe/London, America/New_York, America/Chicago.
SITE_TIMEZONE=Europe/London

# Cache
CACHE_TTL_SECONDS=60

# Row threshold before switching to filtered-only retrieval
LIST_ROW_THRESHOLD=1000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
